# Banco de dados (Supabase)
# Transaction Pooler - porta 6543 - usado pela aplicação
# connection_limit: use 1 em SERVERLESS (Vercel Functions/Lambda). Em servidor
# PERSISTENTE (Railway/Render/VPS) use um valor maior (ex.: 5) para suportar
# requisições concorrentes, senão o pool de 1 conexão estoura sob carga.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=20
# Session Pooler - porta 5432 - usado apenas para migrations
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase (apenas backend — NUNCA expor no frontend)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Admin seed
ADMIN_EMAIL=admin@clinica.com
ADMIN_PASSWORD=troque-esta-senha

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App
PORT=3333
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Dados da clínica
CLINICA_NOME=[NOME DA CLÍNICA]
CLINICA_ENDERECO=
CLINICA_WHATSAPP=
CLINICA_INSTAGRAM=
